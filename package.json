{
  "name": "classia-saas",
  "version": "0.1.0",
  "private": true,
  "description": "SaaS escolar multi-tenant con web, backend y app movil.",
  "packageManager": "pnpm@10.33.4",
  "scripts": {
    "postinstall": "pnpm --filter @classia/database db:generate",
    "dev": "pnpm -r --parallel dev",
    "dev:web": "pnpm --filter @classia/web dev",
    "dev:api": "pnpm --filter api start:dev",
    "dev:mobile": "pnpm --filter mobile start",
    "ports:free": "node scripts/dev/free-port.mjs 3000 3001",
    "ports:free:force": "node scripts/dev/free-port.mjs 3000 3001 --force",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "build": "pnpm -r build",
    "verify:rls": "dotenv -e .env -e .env.example -- tsx scripts/verify-rls.ts"
  },
  "keywords": [
    "saas",
    "school",
    "multi-tenant",
    "nextjs",
    "nestjs",
    "expo"
  ],
  "author": "Juan Jose Toro",
  "license": "UNLICENSED",
  "devDependencies": {
    "dotenv-cli": "^7.4.4",
    "eslint": "^9.39.5",
    "prettier": "^3.8.3",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3"
  }
}
