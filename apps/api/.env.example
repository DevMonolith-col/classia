# Database — must match docker-compose.yml credentials
DATABASE_URL="postgresql://classia:classia@localhost:5432/classia_saas"

# JWT — change this to a long random string in production
JWT_SECRET="classia-dev-secret-change-in-prod"

# Frontend URL for CORS
WEB_URL="http://localhost:3000"

# API port (optional — defaults to 3001)
PORT=3001
