{
  "name": "@classia/database",
  "version": "0.1.0",
  "private": true,
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "lint": "echo \"lint database pendiente\"",
    "typecheck": "tsc --noEmit",
    "test": "echo \"test database pendiente\"",
    "build": "echo \"build database pendiente\"",
    "prisma": "dotenv -e ../../.env -e ../../.env.example -- prisma",
    "db:generate": "dotenv -e ../../.env -e ../../.env.example -- prisma generate",
    "db:migrate": "dotenv -e ../../.env -e ../../.env.example -- prisma migrate dev",
    "db:migrate:init": "dotenv -e ../../.env -e ../../.env.example -- prisma migrate dev --name init_backend_v1",
    "db:studio": "dotenv -e ../../.env -e ../../.env.example -- prisma studio",
    "seed:demo": "dotenv -e ../../.env -e ../../.env.example -- tsx prisma/seed.ts",
    "seed:massive": "dotenv -e ../../.env -e ../../.env.example -- tsx prisma/seed-massive.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "bcryptjs": "^3.0.3",
    "dotenv-cli": "^7.4.4",
    "prisma": "^5.22.0",
    "tsx": "^4.19.0"
  }
}
