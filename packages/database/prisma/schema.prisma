generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum TenantStatus {
  DEMO
  PILOT
  ACTIVE
  SUSPENDED
  CANCELLED
}

enum UserStatus {
  PENDING
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum UserRole {
  SUPER_ADMIN
  SUPPORT_AGENT
  TENANT_ADMIN
  PRINCIPAL
  COORDINATOR
  SECRETARY
  TEACHER
  GUARDIAN
  STUDENT
}

enum MembershipStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  JUSTIFIED
  PERMISSION
}

// ─── SaaS Core ───────────────────────────────────────────────────────────────

model Tenant {
  id            String       @id @default(uuid())
  name          String
  slug          String       @unique
  primaryDomain String?
  status        TenantStatus @default(ACTIVE)
  logoUrl       String?
  brandColor    String?
  timezone      String       @default("America/Bogota")
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  memberships   TenantMembership[]
  sessions      AuthSession[]
  students      Student[]
  groups        Group[]
  subjects      Subject[]
  announcements Announcement[]

  @@map("tenants")
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String
  firstName    String
  lastName     String
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  memberships      TenantMembership[]
  sessions         AuthSession[]
  teacher          Teacher?
  guardian         Guardian?
  student          Student?
  sentMessages     Message[]          @relation("SentMessages")
  receivedMessages Message[]          @relation("ReceivedMessages")

  @@map("users")
}

model TenantMembership {
  id        String           @id @default(uuid())
  tenantId  String
  userId    String
  role      UserRole
  status    MembershipStatus @default(ACTIVE)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([tenantId, userId])
  @@map("tenant_memberships")
}

model AuthSession {
  id               String    @id @default(uuid())
  userId           String
  tenantId         String?
  refreshTokenHash String    @unique
  expiresAt        DateTime
  revokedAt        DateTime?
  ipAddress        String?
  userAgent        String?
  createdAt        DateTime  @default(now())

  user   User    @relation(fields: [userId], references: [id])
  tenant Tenant? @relation(fields: [tenantId], references: [id])

  @@map("auth_sessions")
}

// ─── Institución ─────────────────────────────────────────────────────────────

model Group {
  id       String @id @default(uuid())
  tenantId String
  name     String
  grade    String
  section  String

  tenant             Tenant              @relation(fields: [tenantId], references: [id])
  students           Student[]
  schedules          Schedule[]
  attendanceSessions AttendanceSession[]
  homework           Homework[]

  @@map("groups")
}

model Subject {
  id       String  @id @default(uuid())
  tenantId String
  name     String
  code     String?

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  schedules Schedule[]
  marks     Mark[]
  homework  Homework[]

  @@map("subjects")
}

// ─── Personas ────────────────────────────────────────────────────────────────

model Student {
  id         String    @id @default(uuid())
  tenantId   String
  userId     String?   @unique
  firstName  String
  lastName   String
  documentId String?
  birthDate  DateTime?
  groupId    String?
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  user                User?                @relation(fields: [userId], references: [id])
  group               Group?               @relation(fields: [groupId], references: [id])
  guardians           StudentGuardian[]
  attendanceRecords   AttendanceRecord[]
  marks               Mark[]
  homeworkSubmissions HomeworkSubmission[]
  quizAttempts        QuizAttempt[]

  @@unique([tenantId, documentId])
  @@map("students")
}

model Guardian {
  id       String @id @default(uuid())
  userId   String @unique
  tenantId String

  user     User              @relation(fields: [userId], references: [id])
  students StudentGuardian[]

  @@map("guardians")
}

model StudentGuardian {
  studentId    String
  guardianId   String
  relationship String  @default("parent")
  isPrimary    Boolean @default(true)

  student  Student  @relation(fields: [studentId], references: [id])
  guardian Guardian @relation(fields: [guardianId], references: [id])

  @@id([studentId, guardianId])
  @@map("student_guardians")
}

model Teacher {
  id       String @id @default(uuid())
  userId   String @unique
  tenantId String

  user               User                @relation(fields: [userId], references: [id])
  schedules          Schedule[]
  attendanceSessions AttendanceSession[]
  marks              Mark[]
  homework           Homework[]

  @@map("teachers")
}

// ─── Académico ───────────────────────────────────────────────────────────────

model Schedule {
  id        String  @id @default(uuid())
  tenantId  String
  groupId   String
  subjectId String
  teacherId String
  dayOfWeek Int
  startTime String
  endTime   String
  room      String?

  group              Group               @relation(fields: [groupId], references: [id])
  subject            Subject             @relation(fields: [subjectId], references: [id])
  teacher            Teacher             @relation(fields: [teacherId], references: [id])
  attendanceSessions AttendanceSession[]

  @@map("schedules")
}

model AttendanceSession {
  id         String   @id @default(uuid())
  tenantId   String
  scheduleId String?
  groupId    String
  teacherId  String
  date       DateTime
  isOpen     Boolean  @default(true)
  createdAt  DateTime @default(now())

  schedule Schedule?         @relation(fields: [scheduleId], references: [id])
  group    Group              @relation(fields: [groupId], references: [id])
  teacher  Teacher            @relation(fields: [teacherId], references: [id])
  records  AttendanceRecord[]

  @@map("attendance_sessions")
}

model AttendanceRecord {
  id          String           @id @default(uuid())
  sessionId   String
  studentId   String
  status      AttendanceStatus
  observation String?

  session AttendanceSession @relation(fields: [sessionId], references: [id])
  student Student           @relation(fields: [studentId], references: [id])

  @@unique([sessionId, studentId])
  @@map("attendance_records")
}

model Mark {
  id          String   @id @default(uuid())
  tenantId    String
  studentId   String
  subjectId   String
  teacherId   String
  homeworkId  String?
  title       String
  value       Float
  maxValue    Float    @default(100)
  period      Int      @default(1)
  date        DateTime @default(now())
  isPublished Boolean  @default(true)

  student  Student   @relation(fields: [studentId], references: [id])
  subject  Subject   @relation(fields: [subjectId], references: [id])
  teacher  Teacher   @relation(fields: [teacherId], references: [id])
  homework Homework? @relation(fields: [homeworkId], references: [id])

  @@map("marks")
}

model Homework {
  id             String   @id @default(uuid())
  tenantId       String
  teacherId      String
  subjectId      String
  groupId        String
  title          String
  description    String?
  dueDate        DateTime
  weight         Float    @default(0)
  type           String   @default("TAREA")
  allowNavigation Boolean @default(true)
  attachmentKey  String?
  attachmentName String?
  status         String   @default("ACTIVE")
  createdAt      DateTime @default(now())

  teacher     Teacher              @relation(fields: [teacherId], references: [id])
  subject     Subject              @relation(fields: [subjectId], references: [id])
  group       Group                @relation(fields: [groupId], references: [id])
  submissions HomeworkSubmission[]
  marks       Mark[]
  questions   Question[]
  attempts    QuizAttempt[]

  @@map("homework")
}

model Question {
  id         String   @id @default(uuid())
  homeworkId String
  type       String
  text       String
  points     Float    @default(1)
  imageKey   String?
  imageName  String?
  order      Int      @default(0)
  createdAt  DateTime @default(now())

  homework Homework         @relation(fields: [homeworkId], references: [id])
  options  QuestionOption[]
  answers  QuizAnswer[]

  @@map("questions")
}

model QuestionOption {
  id         String  @id @default(uuid())
  questionId String
  text       String
  isCorrect  Boolean @default(false)
  feedback   String?
  order      Int     @default(0)

  question Question     @relation(fields: [questionId], references: [id])
  answers  QuizAnswer[] @relation("SelectedOption")

  @@map("question_options")
}

model QuizAttempt {
  id          String    @id @default(uuid())
  tenantId    String
  homeworkId  String
  studentId   String
  status      String    @default("IN_PROGRESS")
  score       Float?
  maxScore    Float?
  startedAt   DateTime  @default(now())
  submittedAt DateTime?

  homework Homework     @relation(fields: [homeworkId], references: [id])
  student  Student      @relation(fields: [studentId], references: [id])
  answers  QuizAnswer[]

  @@unique([homeworkId, studentId])
  @@map("quiz_attempts")
}

model QuizAnswer {
  id               String   @id @default(uuid())
  attemptId        String
  questionId       String
  selectedOptionId String?
  textAnswer       String?
  isCorrect        Boolean?
  pointsAwarded    Float?

  attempt        QuizAttempt     @relation(fields: [attemptId], references: [id])
  question       Question        @relation(fields: [questionId], references: [id])
  selectedOption QuestionOption? @relation("SelectedOption", fields: [selectedOptionId], references: [id])

  @@unique([attemptId, questionId])
  @@map("quiz_answers")
}

model HomeworkSubmission {
  id             String    @id @default(uuid())
  homeworkId     String
  studentId      String
  status         String    @default("PENDING")
  attachmentKey  String?
  attachmentName String?
  submittedAt    DateTime?

  homework Homework @relation(fields: [homeworkId], references: [id])
  student  Student  @relation(fields: [studentId], references: [id])

  @@unique([homeworkId, studentId])
  @@map("homework_submissions")
}

// ─── Comunicaciones ──────────────────────────────────────────────────────────

model Message {
  id        String   @id @default(uuid())
  tenantId  String
  fromId    String
  toId      String
  subject   String?
  body      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  from User @relation("SentMessages", fields: [fromId], references: [id])
  to   User @relation("ReceivedMessages", fields: [toId], references: [id])

  @@map("messages")
}

model Announcement {
  id         String   @id @default(uuid())
  tenantId   String
  title      String
  body       String
  targetRole String?
  createdAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("announcements")
}

// ─── Audit ───────────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  tenantId   String?
  userId     String?
  actorRole  String?
  action     String
  entityType String?
  entityId   String?
  oldValues  Json?
  newValues  Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@map("audit_logs")
}
