# App
NODE_ENV=development
PORT=3005
APP_DOMAIN=classia.com.co
APP_WEB_URL=http://localhost:3006
APP_API_URL=http://localhost:3005

# Database
DATABASE_URL="postgresql://classia:classia@localhost:5433/classia_saas?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# Auth
JWT_SECRET="change-me"
REFRESH_TOKEN_SECRET="change-me-too"

# Storage S3/R2
S3_ENDPOINT=""
S3_REGION="auto"
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# Email
EMAIL_PROVIDER="disabled"
EMAIL_FROM="notificaciones@classia.com.co"

# Expo
EXPO_PUBLIC_API_URL="http://localhost:3005"
