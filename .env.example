# App
NODE_ENV=development
PORT=3001
APP_DOMAIN=classia.com.co
APP_WEB_URL=http://localhost:3000
# En desarrollo las IPs de red local se permiten automaticamente.
# Esta variable es para origenes explicitos adicionales o produccion.
APP_CORS_ORIGINS=http://localhost:3000
APP_API_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_TENANT_SLUG=demo

# Database
# DATABASE_URL: rol "classia" (superuser, dueno de las tablas) -- SOLO para
# correr migraciones (prisma migrate). Nunca usarlo para la conexion en
# runtime de la app: un superuser ignora Row-Level Security sin excepcion
# (ver docs/planning/aislamiento-rls-multitenant.md, trampa #7).
DATABASE_URL="postgresql://classia:classia@localhost:5434/classia_saas?schema=public"
# DATABASE_URL_APP: rol "classia_app" (sin privilegios de superuser) -- la
# conexion real que usa PrismaService en runtime, para que RLS aplique.
DATABASE_URL_APP="postgresql://classia_app:classia_app@localhost:5434/classia_saas?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# Auth
JWT_SECRET="change-me"
REFRESH_TOKEN_SECRET="change-me-too"

# Storage S3/R2
S3_ENDPOINT=""
S3_REGION="auto"
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# Email
EMAIL_PROVIDER="disabled"
EMAIL_FROM="notificaciones@classia.com.co"

# Expo
EXPO_PUBLIC_API_URL="http://localhost:3001"
